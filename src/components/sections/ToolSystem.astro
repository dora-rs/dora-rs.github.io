---
import Section from 'components/layout/Section.astro';
import Container from 'components/layout/Container.astro';
import DistributedFlow from 'components/DistributedFlow.jsx';
---

<Section background="secondary" padY="lg">
  <Container>
    <div class="mb-8 reveal">
      <p class="font-mono text-[16px] uppercase tracking-[0.08em] text-neutral-2">Distributed</p>
      <h2 class="mt-3 text-[28px] tracking-[-0.03em] md:text-[36px] lg:text-[48px]">
        Run anywhere, scale everywhere
      </h2>
      <p class="mt-4 max-w-2xl text-[16px] leading-relaxed text-neutral-2">
        Local shared memory between co-located nodes, automatic Zenoh pub-sub for
        cross-machine communication. SSH-based cluster management with label scheduling
        and rolling upgrades.
      </p>
    </div>

    <!-- Full-width distributed architecture flow chart -->
    <div class="mb-8 rounded-lg border border-surface-3 bg-surface-1 p-6 reveal">
      <DistributedFlow client:only="react" />
    </div>

    <div class="space-y-4">
      <div class="flex items-center gap-6 rounded-lg border border-surface-3 bg-surface-1 p-5 reveal">
        <span class="shrink-0 font-mono text-[28px] text-text-bright">6013</span>
        <div>
          <p class="font-mono text-[15px] uppercase tracking-[0.08em] text-accent">WebSocket control plane</p>
          <p class="text-[16px] text-neutral-2">Coordinator manages all daemons via persistent WebSocket connections</p>
        </div>
      </div>
      <div class="flex items-center gap-6 rounded-lg border border-surface-3 bg-surface-1 p-5 reveal">
        <span class="shrink-0 font-mono text-[28px] text-text-bright">SSH</span>
        <div>
          <p class="font-mono text-[15px] uppercase tracking-[0.08em] text-heading">Cluster deployment</p>
          <p class="text-[16px] text-neutral-2">Deploy across machines with <code class="text-code">dora cluster up</code> — no Kubernetes needed</p>
        </div>
      </div>
      <div class="flex items-center gap-6 rounded-lg border border-surface-3 bg-surface-1 p-5 reveal">
        <span class="shrink-0 font-mono text-[28px] text-text-bright">0</span>
        <div>
          <p class="font-mono text-[15px] uppercase tracking-[0.08em] text-title">Zero-copy IPC</p>
          <p class="text-[16px] text-neutral-2">Shared memory for local nodes, Zenoh SHM for cross-machine — no serialization overhead</p>
        </div>
      </div>
    </div>
  </Container>
</Section>
