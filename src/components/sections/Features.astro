---
import Section from 'components/layout/Section.astro';
import Container from 'components/layout/Container.astro';
import FeatureCard from './FeatureCard.astro';
import features from 'data/features.json';
---

<Section id="features" padY="lg">
  <Container>
    <div class="mb-12 lg:mb-16" data-animate>
      <p class="font-mono text-[16px] uppercase tracking-[0.08em] text-neutral-2">Core Capabilities</p>
      <h2 class="mt-3 text-[28px] tracking-[-0.03em] text-text-bright md:text-[36px] lg:text-[48px]">
        Why dora 1.0
      </h2>
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3" data-animate-stagger>
      {features.map((feature) => (
        <FeatureCard
          title={feature.title}
          description={feature.description}
          stat={feature.stat}
          statLabel={feature.statLabel}
        />
      ))}
    </div>
  </Container>
</Section>
