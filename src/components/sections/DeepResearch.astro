---
import SvgSection from 'components/ui/SvgSection.astro';
import PipelineFlow from 'components/PipelineFlow.jsx';

const patterns = [
  { name: 'Topic', color: 'text-accent', description: 'Fire-and-forget pub/sub for sensor data, periodic status, and events' },
  { name: 'Service', color: 'text-heading', description: 'Request/reply with UUID correlation. Client sends request, server returns exactly one response' },
  { name: 'Action', color: 'text-title', description: 'Long-running goals with periodic feedback and cancellation support' },
  { name: 'Streaming', color: 'text-accent', description: 'Continuous data with session/segment/chunk metadata and queue flushing for real-time interruption' },
];
---

<SvgSection bgSrc="/images/bg-circuit-panel.png">
  <!-- Text panel -->
  <div class="glass-panel mb-8 reveal">
    <p class="font-mono text-[16px] uppercase tracking-[0.08em] text-neutral-2">Communication Patterns</p>
    <h2 class="mt-3 text-[28px] tracking-[-0.03em] md:text-[36px] lg:text-[48px]">
      Four ways to communicate
    </h2>
    <p class="mt-4 max-w-2xl text-[16px] leading-relaxed text-neutral-2">
      Beyond pub/sub. dora provides Topic, Service, Action, and Streaming patterns
      via well-known metadata keys. No daemon or YAML changes required.
    </p>
  </div>

  <!-- Full-width React Flow diagram -->
  <div class="glass-panel mb-8 reveal">
    <PipelineFlow client:only="react" />
  </div>

  <!-- Pattern cards -->
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {patterns.map((p, i) => (
      <div class="glass-panel reveal" style={`animation-delay: ${i * 100}ms`}>
        <p class:list={['font-mono text-[15px] uppercase tracking-[0.08em]', p.color]}>{p.name}</p>
        <p class="mt-2 text-[16px] leading-relaxed text-neutral-2">{p.description}</p>
      </div>
    ))}
  </div>
</SvgSection>
