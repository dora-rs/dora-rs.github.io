---
import ThemeToggle from 'components/ui/ThemeToggle.astro';

const base = '';
const isZhCn = Astro.url.pathname.includes('/zh-cn');
const langSwitchHref = isZhCn ? `${base}/` : `${base}/zh-cn/`;
const langSwitchLabel = isZhCn ? 'EN' : 'CN';

const navLinks = isZhCn ? [
  { text: '特性', href: '#features' },
  { text: '架构', href: '#architecture' },
  { text: '性能', href: '#performance' },
  { text: '对比', href: `${base}/zh-cn/comparison` },
  { text: '快速开始', href: '#quickstart' },
] : [
  { text: 'Features', href: '#features' },
  { text: 'Architecture', href: '#architecture' },
  { text: 'Performance', href: '#performance' },
  { text: 'Comparison', href: `${base}/comparison` },
  { text: 'Quick Start', href: '#quickstart' },
];

const externalLinks = isZhCn ? [
  { text: '手册', href: `${base}/zh-cn/book` },
  { text: 'GitHub', href: 'https://github.com/dora-rs/adora' },
] : [
  { text: 'Book', href: `${base}/book` },
  { text: 'GitHub', href: 'https://github.com/dora-rs/adora' },
];

const homeHref = isZhCn ? `${base}/zh-cn/` : `${base}/`;
---

<header class="fixed top-0 z-50 w-full max-w-[1920px] border-b border-surface-3 bg-bg/90 backdrop-blur-sm">
  <div class="flex items-center justify-between px-4 py-4 lg:px-9">
    <!-- Logo -->
    <a href={homeHref} class="flex items-center gap-2 font-mono text-[16px] uppercase tracking-[0.08em] text-text-bright">
      <img src="/images/adora-logo.svg" alt="Adora" class="header-logo-light h-6 w-6" />
      <img src="/images/adora-logo-dark.svg" alt="Adora" class="header-logo-dark h-6 w-6" />
      ADORA
    </a>

    <!-- Desktop Nav -->
    <nav class="nav-group hidden items-center gap-8 lg:flex">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="link-animated font-mono text-[16px] uppercase leading-none tracking-[0.08em] text-text"
        >
          {link.text}
        </a>
      ))}
      <span class="h-3 w-px bg-surface-3" />
      {externalLinks.map((link) => (
        <a
          href={link.href}
          target={link.href.startsWith('http') ? '_blank' : undefined}
          rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          class="link-animated font-mono text-[16px] uppercase leading-none tracking-[0.08em] text-text"
        >
          {link.text}
        </a>
      ))}
      <span class="h-3 w-px bg-surface-3" />
      <a href={langSwitchHref} class="font-mono text-[16px] uppercase leading-none tracking-[0.08em] text-accent transition-colors hover:text-title">{langSwitchLabel}</a>
      <ThemeToggle />
    </nav>

    <!-- Mobile: Theme Toggle + Menu Button -->
    <div class="flex items-center gap-3 lg:hidden">
      <ThemeToggle />
      <button
        id="menu-toggle"
        class="flex size-8 items-center justify-center"
        aria-label="Toggle menu"
      >
        <span class="menu-icon flex flex-col gap-1.5">
          <span class="block h-px w-5 bg-text transition-all duration-300" />
          <span class="block h-px w-5 bg-text transition-all duration-300" />
        </span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden border-t border-surface-3 bg-bg px-4 py-8 lg:hidden">
    <nav class="flex flex-col gap-6">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="link-animated font-mono text-[16px] uppercase tracking-[0.08em] text-text"
        >
          {link.text}
        </a>
      ))}
      <span class="h-px w-full bg-surface-3" />
      {externalLinks.map((link) => (
        <a
          href={link.href}
          target={link.href.startsWith('http') ? '_blank' : undefined}
          rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          class="link-animated font-mono text-[16px] uppercase tracking-[0.08em] text-text"
        >
          {link.text}
        </a>
      ))}
      <span class="h-px w-full bg-surface-3" />
      <a href={langSwitchHref} class="font-mono text-[16px] uppercase tracking-[0.08em] text-accent">{langSwitchLabel}</a>
    </nav>
  </div>
</header>

<style is:global>
  /* Logo swap: white by default, dark in light mode */
  .header-logo-light { display: inline; }
  .header-logo-dark { display: none; }
  html[data-theme="light"] .header-logo-light { display: none !important; }
  html[data-theme="light"] .header-logo-dark { display: inline !important; }
</style>

<style>
  .nav-group:hover a {
    opacity: 0.6;
    transition: opacity 0.25s ease;
  }
  .nav-group:hover a:hover {
    opacity: 1;
  }

  .menu-open .menu-icon span:first-child {
    transform: translateY(3.5px) rotate(45deg);
  }
  .menu-open .menu-icon span:last-child {
    transform: translateY(-3.5px) rotate(-45deg);
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    toggle.classList.toggle('menu-open');
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggle?.classList.remove('menu-open');
    });
  });
</script>
