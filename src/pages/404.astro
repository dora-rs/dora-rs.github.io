---
import Layout from 'layouts/Layout.astro';
import Container from 'components/layout/Container.astro';
import Button from 'components/ui/Button.astro';
---

<Layout title="404 — dora" description="Page not found">
  <div class="flex min-h-[80vh] items-center justify-center px-4">
    <Container narrow class="text-center">
      <p class="font-mono text-[72px] leading-none tracking-[-0.04em] text-surface-3 md:text-[120px]">
        404
      </p>
      <p class="mt-4 text-[18px] text-neutral-2">Page not found</p>
      <div class="mt-8">
        <Button href="/">Back to home</Button>
      </div>
    </Container>
  </div>
</Layout>
